# ─── Base de datos MySQL (Hostinger → hPanel → Databases) ───────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contrasena_mysql
DB_NAME=safaria

# ─── JWT (genera una clave larga y aleatoria) ────────────────────────────
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga

# ─── Puerto (Hostinger lo asigna automáticamente) ───────────────────────
PORT=3000
